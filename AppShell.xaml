<Shell
    x:Class="GeoMapsPrototype.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GeoMapsPrototype"
    xmlns:views="clr-namespace:GraTerenowa.Views;assembly=GeoMapsPrototype"
    FlyoutBehavior="Flyout"
    Title="GeoMaps">

    <FlyoutItem Title="Mapa">
        <ShellContent
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Zestawy zadań">
        <ShellContent
            ContentTemplate="{DataTemplate views:LocationSetListPage}"
            Route="LocationSetListPage" />
    </FlyoutItem>

</Shell>