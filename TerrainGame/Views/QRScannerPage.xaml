<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GraTerenowa.Views.QRScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Skanuj kod QR"
    BackgroundColor="Black">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" x:Name="ScannerContainer" />

        <Border
            Grid.Row="0"
            WidthRequest="220"
            HeightRequest="220"
            StrokeThickness="2"
            Stroke="White"
            StrokeShape="RoundRectangle 12"
            BackgroundColor="Transparent"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            InputTransparent="True" />

        <VerticalStackLayout
            Grid.Row="1"
            Padding="16"
            Spacing="8"
            BackgroundColor="#CC000000">

            <Label
                Text="Skieruj kamerę na kod QR"
                TextColor="White"
                FontSize="14"
                HorizontalOptions="Center" />

            <Button
                Text="Anuluj"
                BackgroundColor="Transparent"
                BorderColor="White"
                BorderWidth="1"
                TextColor="White"
                CornerRadius="10"
                Clicked="OnCancelClicked" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>