<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GraTerenowa.Views.TaskDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GraTerenowa.ViewModels"
    xmlns:conv="clr-namespace:GraTerenowa.Converters"
    Title="Zadanie">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InvertBoolConverter      x:Key="InvertBoolConverter" />
            <conv:StringNotEmptyConverter  x:Key="StringNotEmptyConverter" />
            <conv:BoolToColorConverter     x:Key="BoolToColorConverter" />
            <conv:TaskTypeToButtonTextConverter x:Key="TaskTypeToButtonTextConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- 5 wierszy: nawigacja / treść / przycisk wykonania / postęp / zatwierdzenie -->
    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Padding="16" RowSpacing="0">

        <!-- ── Wiersz 0: Nawigacja między zadaniami ── -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="Auto,*,Auto"
            Margin="0,0,0,16">

            <Button
                Grid.Column="0"
                Text="&#8592;"
                WidthRequest="44"
                HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="Transparent"
                BorderColor="Gray"
                BorderWidth="1"
                Command="{Binding PrevTaskCommand}"
                IsEnabled="{Binding HasPrevTask}" />

            <Label
                Grid.Column="1"
                Text="{Binding ProgressText}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                FontSize="14"
                TextColor="Gray" />

            <Button
                Grid.Column="2"
                Text="&#8594;"
                WidthRequest="44"
                HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="Transparent"
                BorderColor="Gray"
                BorderWidth="1"
                Command="{Binding NextTaskCommand}"
                IsEnabled="{Binding HasNextTask}" />
        </Grid>

        <!-- ── Wiersz 1: Treść zadania ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="0,0,0,8">

                <!-- Tytuł -->
                <Label
                    Text="{Binding CurrentTask.Title}"
                    FontSize="22"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center" />

                <!-- Etykieta typu -->
                <Border
                    BackgroundColor="#E3F2FD"
                    StrokeShape="RoundRectangle 8"
                    Padding="10,4"
                    HorizontalOptions="Center">
                    <Label
                        Text="{Binding CurrentTask.TypeDisplayName}"
                        FontSize="12"
                        TextColor="#1565C0" />
                </Border>

                <!-- ── Question (otwarte) ── -->
                <VerticalStackLayout
                    IsVisible="{Binding IsQuestion}"
                    Spacing="12">

                    <Label
                        Text="{Binding QuestionText}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Margin="0,8" />

                    <Entry
                        Placeholder="Twoja odpowiedź..."
                        Text="{Binding UserInput}"
                        IsEnabled="{Binding IsCompleted,
                            Converter={StaticResource InvertBoolConverter}}"
                        HorizontalOptions="FillAndExpand" />
                </VerticalStackLayout>

                <!-- ── QRCode ── -->
                <VerticalStackLayout
                    IsVisible="{Binding IsQRCode}"
                    Spacing="12"
                    HorizontalOptions="Center">

                    <Label
                        Text="Znajdź i zeskanuj kod QR w tym miejscu"
                        FontSize="15"
                        HorizontalTextAlignment="Center"
                        TextColor="Gray" />

                    <Image
                        Source="qr_placeholder.png"
                        WidthRequest="80"
                        HeightRequest="80"
                        HorizontalOptions="Center"
                        Opacity="0.4" />
                </VerticalStackLayout>

                <!-- ── Action ── -->
                <VerticalStackLayout
                    IsVisible="{Binding IsAction}"
                    Spacing="12">

                    <Label
                        Text="{Binding ActionDescription}"
                        FontSize="15"
                        HorizontalTextAlignment="Center"
                        TextColor="Gray"
                        Margin="0,8" />
                </VerticalStackLayout>

                <!-- ── SingleChoice (A/B/C/D) ── -->
                <VerticalStackLayout
                    IsVisible="{Binding IsSingleChoice}"
                    Spacing="12">

                    <Label
                        Text="{Binding ChoiceQuestionText}"
                        FontSize="16"
                        HorizontalTextAlignment="Center"
                        Margin="0,8" />

                    <!-- Opcje jako przyciski radiowe -->
                    <VerticalStackLayout Spacing="8">
                        <BindableLayout.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>A</x:String>
                                <x:String>B</x:String>
                                <x:String>C</x:String>
                                <x:String>D</x:String>
                            </x:Array>
                        </BindableLayout.ItemsSource>
                    </VerticalStackLayout>

                    <!-- Przyciski A/B/C/D -->
                    <Grid
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="8">

                        <Button
                            Grid.Row="0"
                            Text="{Binding CurrentOptions[0].Text,
                                StringFormat='A:  {0}'}"
                            BackgroundColor="{Binding SelectedOption,
                                Converter={StaticResource OptionSelectedConverter},
                                ConverterParameter='A'}"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="48"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}"
                            Command="{Binding SelectOptionCommand}"
                            CommandParameter="A" />

                        <Button
                            Grid.Row="1"
                            Text="{Binding CurrentOptions[1].Text,
                                StringFormat='B:  {0}'}"
                            BackgroundColor="{Binding SelectedOption,
                                Converter={StaticResource OptionSelectedConverter},
                                ConverterParameter='B'}"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="48"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}"
                            Command="{Binding SelectOptionCommand}"
                            CommandParameter="B" />

                        <Button
                            Grid.Row="2"
                            Text="{Binding CurrentOptions[2].Text,
                                StringFormat='C:  {0}'}"
                            BackgroundColor="{Binding SelectedOption,
                                Converter={StaticResource OptionSelectedConverter},
                                ConverterParameter='C'}"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="48"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}"
                            Command="{Binding SelectOptionCommand}"
                            CommandParameter="C" />

                        <Button
                            Grid.Row="3"
                            Text="{Binding CurrentOptions[3].Text,
                                StringFormat='D:  {0}'}"
                            BackgroundColor="{Binding SelectedOption,
                                Converter={StaticResource OptionSelectedConverter},
                                ConverterParameter='D'}"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="48"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}"
                            Command="{Binding SelectOptionCommand}"
                            CommandParameter="D" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ── MultipleChoice ── -->
                <VerticalStackLayout
                    IsVisible="{Binding IsMultipleChoice}"
                    Spacing="12">

                    <Label
                        Text="{Binding ChoiceQuestionText}"
                        FontSize="16"
                        HorizontalTextAlignment="Center"
                        Margin="0,8" />

                    <Label
                        Text="Zaznacz wszystkie poprawne odpowiedzi:"
                        FontSize="13"
                        TextColor="Gray" />

                    <!-- Checkboxy A/B/C/D -->
                    <Grid
                        ColumnDefinitions="Auto,*"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="10"
                        ColumnSpacing="12">

                        <CheckBox
                            Grid.Row="0" Grid.Column="0"
                            IsChecked="{Binding IsASelected}"
                            Color="#283593"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}" />
                        <Label
                            Grid.Row="0" Grid.Column="1"
                            Text="{Binding CurrentOptions[0].Text,
                                StringFormat='A:  {0}'}"
                            FontSize="15"
                            VerticalOptions="Center" />

                        <CheckBox
                            Grid.Row="1" Grid.Column="0"
                            IsChecked="{Binding IsBSelected}"
                            Color="#283593"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}" />
                        <Label
                            Grid.Row="1" Grid.Column="1"
                            Text="{Binding CurrentOptions[1].Text,
                                StringFormat='B:  {0}'}"
                            FontSize="15"
                            VerticalOptions="Center" />

                        <CheckBox
                            Grid.Row="2" Grid.Column="0"
                            IsChecked="{Binding IsCSelected}"
                            Color="#283593"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}" />
                        <Label
                            Grid.Row="2" Grid.Column="1"
                            Text="{Binding CurrentOptions[2].Text,
                                StringFormat='C:  {0}'}"
                            FontSize="15"
                            VerticalOptions="Center" />

                        <CheckBox
                            Grid.Row="3" Grid.Column="0"
                            IsChecked="{Binding IsDSelected}"
                            Color="#283593"
                            IsEnabled="{Binding IsCompleted,
                                Converter={StaticResource InvertBoolConverter}}" />
                        <Label
                            Grid.Row="3" Grid.Column="1"
                            Text="{Binding CurrentOptions[3].Text,
                                StringFormat='D:  {0}'}"
                            FontSize="15"
                            VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Komunikat wyniku -->
                <Border
                    IsVisible="{Binding ResultMessage,
                        Converter={StaticResource StringNotEmptyConverter}}"
                    BackgroundColor="{Binding IsError,
                        Converter={StaticResource BoolToColorConverter}}"
                    StrokeShape="RoundRectangle 10"
                    Padding="14">
                    <Label
                        Text="{Binding ResultMessage}"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        TextColor="White" />
                </Border>

                <!-- ActivityIndicator weryfikacji -->
                <ActivityIndicator
                    IsVisible="{Binding IsVerifying}"
                    IsRunning="{Binding IsVerifying}"
                    HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Wiersz 2: Przycisk wykonania zadania ── -->
        <Button
            Grid.Row="2"
            Text="{Binding CurrentTask.Type,
                Converter={StaticResource TaskTypeToButtonTextConverter}}"
            BackgroundColor="{Binding IsCompleted,
                Converter={StaticResource BoolToColorConverter}}"
            TextColor="White"
            CornerRadius="12"
            HeightRequest="52"
            Margin="0,12,0,4"
            Command="{Binding ExecuteTaskCommand}"
            IsEnabled="{Binding IsCompleted,
                Converter={StaticResource InvertBoolConverter}}" />

        <!-- ── Wiersz 3: Pasek postępu zestawu ── -->
        <VerticalStackLayout
            Grid.Row="3"
            Spacing="6"
            Margin="0,4,0,4">

            <BoxView
                HeightRequest="1"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                Margin="0,0,0,6" />

            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Grid.Column="0"
                    Text="Postęp zestawu"
                    FontSize="13"
                    TextColor="Gray" />
                <Label
                    Grid.Column="1"
                    Text="{Binding CompletedTasksCount,
                        StringFormat='{0} zaliczonych'}"
                    FontSize="13"
                    TextColor="Gray" />
            </Grid>

            <ProgressBar
                Progress="{Binding SetProgress}"
                ProgressColor="#4CAF50"
                HeightRequest="6" />

        </VerticalStackLayout>

        <!-- ── Wiersz 4: Zatwierdzenie zestawu ── -->

        <!-- Przycisk Zatwierdź zestaw -->
        <Button
            Grid.Row="4"
            Text="Zatwierdź zestaw"
            BackgroundColor="#1565C0"
            TextColor="White"
            CornerRadius="12"
            HeightRequest="52"
            Margin="0,4,0,0"
            IsVisible="{Binding CanSubmitSet}"
            Command="{Binding SubmitSetCommand}" />

        <!-- Panel sprawdzania -->
        <VerticalStackLayout
            Grid.Row="4"
            IsVisible="{Binding IsSubmitting}"
            Spacing="12"
            Margin="0,8,0,0">

            <ActivityIndicator
                IsRunning="{Binding IsSubmitting}"
                Color="#1565C0"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding SubmitStatusMessage}"
                FontSize="14"
                HorizontalOptions="Center"
                TextColor="#1565C0"
                FontAttributes="Italic" />
        </VerticalStackLayout>

        <!-- Panel zatwierdzonego zestawu -->
        <Border
            Grid.Row="4"
            IsVisible="{Binding IsSetApproved}"
            BackgroundColor="#E8F5E9"
            StrokeShape="RoundRectangle 12"
            Padding="16"
            Margin="0,4,0,0">

            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">

                <Label
                    Text="✓"
                    FontSize="36"
                    TextColor="#2E7D32"
                    HorizontalOptions="Center" />

                <Label
                    Text="{Binding SubmitStatusMessage}"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#2E7D32"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Administrator zatwierdził Twój zestaw zadań."
                    FontSize="13"
                    TextColor="#388E3C"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>